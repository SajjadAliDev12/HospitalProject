<UserControl x:Class="Hospital.Desktop.Views.ShiftSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:Hospital.Desktop.Converters"
             mc:Ignorable="d" 
             Background="#F8FAFC" FontFamily="Segoe UI"
             FlowDirection="RightToLeft"
             d:DesignHeight="800" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:DateOnlyConverter x:Key="DateOnlyConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="إعدادات نظام الخفر والدوام" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="تحكم في الدورة الزمنية وأسماء المسؤولين عن الفرق الأربعة" Foreground="#64748B" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.03" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📅 التاريخ المرجعي (بداية الدورة)" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="0,0,0,5"/>
                            <TextBlock Text="هذا التاريخ يمثل اليوم الذي استلم فيه 'الفريق رقم 1' الخفارة لأول مرة." FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                        <DatePicker Grid.Column="1" 
                                    SelectedDate="{Binding ReferenceDate, Converter={StaticResource DateOnlyConverter}}" 
                                    Height="42" Width="250" 
                                    VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Text="توزيع مسؤولي الخفر" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="5,0,0,15"/>

                <ItemsControl ItemsSource="{Binding Teams}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" Padding="20" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.02" Color="Black"/>
                                </Border.Effect>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <Border Width="35" Height="35" Background="#EFF6FF" CornerRadius="17.5">
                                            <TextBlock Text="{Binding Id}" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Id, StringFormat='الفريق رقم {0}'}" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="15" Foreground="#1E293B"/>
                                    </StackPanel>
                                    <TextBlock Text="المسؤول المباشر:" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding DataContext.Employees, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="Name"
                                              SelectedValue="{Binding SupervisorId}"
                                              Text="{Binding LocalSearchText, UpdateSourceTrigger=PropertyChanged}"
                                              IsDropDownOpen="{Binding IsLocalDropDownOpen}"
                                              IsEditable="True"
                                              IsTextSearchEnabled="False"
                                              StaysOpenOnEdit="True"
                                              Style="{StaticResource ModernComboBox}">
                                    </ComboBox>
                                    <TextBlock Text="* ابحث عن الموظف (أدخل 3 أحرف)" FontSize="10" Foreground="#94A3B8" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="White" CornerRadius="12" Padding="25" Margin="0,20,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🖨️ مركز التقارير والطباعة" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="نطاق التقرير:" Style="{StaticResource LabelStyle}"/>
                                <ComboBox SelectedIndex="{Binding SelectedPrintScope}" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15">
                                    <ComboBoxItem Content="قسم محدد فقط"/>
                                    <ComboBoxItem Content="كافة أقسام المستشفى"/>
                                </ComboBox>
                                <StackPanel Visibility="{Binding IsDeptSelectorVisible, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="القسم المطلوب:" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding Departments}" 
                                              SelectedValuePath="Id" DisplayMemberPath="Name"
                                              SelectedValue="{Binding SelectedPrintDeptId}"
                                              Style="{StaticResource ModernComboBox}" Margin="0,0,0,15"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                <TextBlock Text="نوع الجدول:" Style="{StaticResource LabelStyle}"/>
                                <ComboBox SelectedIndex="{Binding SelectedPrintShiftType}" Style="{StaticResource ModernComboBox}" Margin="0,0,0,15">
                                    <ComboBoxItem Content="الدوام الصباحي فقط"/>
                                    <ComboBoxItem Content="جدول الخفر (المسائي) فقط"/>
                                    <ComboBoxItem Content="الكل (صباحي + خفر)"/>
                                </ComboBox>
                                <TextBlock Text="شهر التقرير:" Style="{StaticResource LabelStyle}"/>
                                <DatePicker SelectedDate="{Binding ReportMonth}" Height="40"/>
                            </StackPanel>
                        </Grid>
                        <Separator Margin="0,20" Background="#F1F5F9"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="معاينة الجدول" Command="{Binding PreviewReportCommand}" 
                                    Style="{StaticResource ActionBtn}" Background="#0F172A" Foreground="White" Width="150"/>
                            <Button Content="طباعة فورية" Command="{Binding PrintReportCommand}" 
                                    Style="{StaticResource ActionBtn}" Background="#2563EB" Foreground="White" Width="150" Margin="15,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="20,15" CornerRadius="12" Margin="0,20,0,0" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Button Content="حفظ إعدادات النظام" 
                        Command="{Binding SaveCommand}" 
                        Style="{StaticResource ActionBtn}" 
                        Background="#2563EB" 
                        Foreground="White" 
                        Width="200" Height="45"/>
                <Button Content="تحديث البيانات" 
                        Command="{Binding RefreshCommand}" 
                        Background="Transparent" 
                        Foreground="#64748B" 
                        FontWeight="SemiBold"
                        Margin="20,0,0,0" 
                        Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>